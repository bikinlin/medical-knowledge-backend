{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate=600" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/news",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/tech",
      "schedule": "0 6 * * *"
    }
  ]
}
